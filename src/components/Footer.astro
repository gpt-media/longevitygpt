---
import type { Edition } from '../lib/editions';
import { editionsByCountry, pagePath } from '../lib/editions';
import { SITE, UI } from '../lib/site';

interface Props {
  edition: Edition;
  /** Accepted for call-site compatibility; unused — the switcher links to edition homepages. */
  slug?: string | null;
  presentEditions?: Edition[];
  pathOverride?: string;
}
const { edition } = Astro.props;
const t = UI[edition.ui];
const year = 2026;

// Region/language switcher lives in the footer as a compact zero-JS <details> disclosure
// (clean, authority-style header; hreflang in <head> does the search-engine routing).
// No auto-redirect — the reader chooses. Links go to edition HOMEPAGES, not per-page
// alternates; the current edition renders bold and non-linked. Edition links stay in the
// DOM whether the disclosure is open or closed, so they remain crawlable.
const groups = editionsByCountry();
---
<footer class="site-footer">
  <div class="wrap">
    <nav class="footer-nav">
      <a href="/reports/healthspan-gap-2026/">{t.footerReports}</a>
      <a href="/about/">{t.navAbout}</a>
      <a href="/editorial-standards/">{t.footerEditorial}</a>
      <a href="/how-we-review/">{t.footerHowWeReview}</a>
      <a href="/medical-disclaimer/">{t.footerDisclaimer}</a>
      <a href="/privacy/">{t.footerPrivacy}</a>
    </nav>
    <details class="lang-switch">
      <summary><span class="ls-globe" aria-hidden="true">🌐</span>{t.footerLanguage}</summary>
      <ul class="ls-list" aria-label={t.pickerLabel}>
        {groups.map((g) => (
          <li class="ls-row">
            <span class="ls-flag" aria-hidden="true">{g.flag}</span>
            <span class="ls-region">{g.country}:</span>
            {g.editions.map((e, i) => (
              <>
                {i > 0 && <span class="ls-sep">·</span>}
                {e.key === edition.key ? (
                  <strong class="ls-on" aria-current="true">{e.langLabel}</strong>
                ) : (
                  <a href={pagePath(e)}>{e.langLabel}</a>
                )}
              </>
            ))}
          </li>
        ))}
      </ul>
    </details>
    <p class="fineprint">{t.disclaimerLine}</p>
    <p class="fineprint">&copy; {year} {SITE.name}. {t.rights}</p>
  </div>
</footer>
